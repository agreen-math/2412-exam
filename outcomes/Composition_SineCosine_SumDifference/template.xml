<knowl xmlns="http://checkit.math.psu.edu"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://checkit.math.psu.edu checkit.xsd"
       version="0.9">

  <intro>
    Evaluate the following expression exactly. No calculator is allowed.
  </intro>

  <content>
    <p>
      <m>{{expression}}</m>
    </p>
  </content>

  <outtro>
    <p>
      Category: {{category}}
    </p>
  </outtro>

  <answer>
    <me>{{answer}}</me>
  </answer>

</knowl>