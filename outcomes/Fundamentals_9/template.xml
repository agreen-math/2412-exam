      <item><p><m>(d)\ [0,2\pi): {{q4}},\ \theta=\underline{\hspace{1.2in}}</m></p></item>
      <item><p><m>(e)\ [0,2\pi): {{q5}},\ \theta=\underline{\hspace{1.2in}}</m></p></item>
      <item><p><m>(f)\ [0,2\pi): {{q6}},\ \theta=\underline{\hspace{1.2in}}</m></p></item>
    </list>
  </content>

  <outtro>
    <p><b>Solutions.</b></p>
